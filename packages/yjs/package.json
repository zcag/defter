{
  "name": "@defterjs/yjs",
  "version": "0.1.4",
  "description": "Bind a Defter grid to a Yjs Y.Text for collaboration. Inject the shared type; the transport, persistence, and awareness stay entirely the host's concern.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@defterjs/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "yjs": "^13"
  },
  "author": "Cagdas Salur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcag/defter.git",
    "directory": "packages/yjs"
  },
  "homepage": "https://defter.cagdas.io",
  "bugs": "https://github.com/zcag/defter/issues"
}
