{
  "name": "@defterjs/core",
  "version": "0.1.5",
  "description": "Headless, framework-agnostic core for Defter \u2014 a text-canonical collaborative spreadsheet. Parse/serialize, coordinates, minimal-splice edits, reference rewriting, projection.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ./scripts/gen-authoring-guide.mjs && tsc -b",
    "prepublishOnly": "node ./scripts/gen-authoring-guide.mjs && tsc -b"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcag/defter.git",
    "directory": "packages/core"
  },
  "author": "Cagdas Salur",
  "homepage": "https://defter.cagdas.io",
  "bugs": "https://github.com/zcag/defter/issues"
}
