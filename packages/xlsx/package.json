{
  "name": "@defterjs/xlsx",
  "version": "0.1.4",
  "description": "XLSX import/export for Defter, via exceljs. Maps cells, formulas, merges, and basic styling to and from the Defter model. Optional \u2014 not part of core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@defterjs/core": "workspace:*",
    "exceljs": "^4.4.0"
  },
  "author": "Cagdas Salur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcag/defter.git",
    "directory": "packages/xlsx"
  },
  "homepage": "https://defter.cagdas.io",
  "bugs": "https://github.com/zcag/defter/issues"
}
