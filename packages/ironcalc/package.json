{
  "name": "@defter/ironcalc",
  "version": "0.1.0",
  "description": "IronCalc-wasm formula engine adapter for Defter \u2014 proves the pluggable-engine seam with a mature Rust/Wasm engine (300+ functions). Optional; the default is @defter/formula.",
  "license": "MIT",
  "type": "module",
