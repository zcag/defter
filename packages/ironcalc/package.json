      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@defter/core": "workspace:*",
    "@ironcalc/wasm": "^0.7.0"
  },
  "author": "Cagdas Salur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcag/defter.git",
