{
  "name": "@defterjs/react",
  "version": "0.1.1",
  "description": "React renderer for Defter \u2014 a thin, themeable (CSS-variable) grid projection of the text model. Bring your own Y.Text for collaboration.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc -b && node ./scripts/copy-css.mjs",
    "prepublishOnly": "tsc -b && node ./scripts/copy-css.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@defterjs/core": "workspace:*"
  },
  "devDependencies": {
    "@defterjs/formula": "workspace:*",
    "@storybook/react": "^8.5.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "author": "Cagdas Salur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcag/defter.git",
    "directory": "packages/react"
  },
  "homepage": "https://defter.cagdas.io",
  "bugs": "https://github.com/zcag/defter/issues"
}
