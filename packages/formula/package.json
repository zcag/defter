{
  "name": "@defter/formula",
  "version": "0.0.1",
  "description": "Default formula engine for Defter — a compact, dependency-free Excel-style evaluator implementing the @defter/core FormulaEngine interface.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
